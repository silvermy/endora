{
  "name": "Gesture Cam",
  "version": "1.2.0",
  "slug": "gesture_cam",
  "description": "Gesture detection via RTSP cameras — raises HA events on wave/flick/fist gestures. Works sitting, standing, or laying down.",
  "url": "https://github.com/silvermy/gesture_cam",
  "init": false,
  "arch": ["aarch64", "amd64"],
  "startup": "application",
  "boot": "auto",
  "options": {
    "rtsp_url_a": "rtsp://user:pass@192.168.1.100:554/stream1",
    "rtsp_url_b": "rtsp://user:pass@192.168.1.101:554/stream1",
    "rtsp_transport": "tcp",
    "rtsp_reconnect_delay_s": 5.0,
    "frame_width": 640,
    "frame_height": 480,
    "hand_model_max_hands": 1,
    "hand_min_detection_confidence": 0.5,
    "hand_min_tracking_confidence": 0.5,
    "wave_velocity_threshold_px": 15.0,
    "wave_sustain_frames": 1,
    "vertical_velocity_threshold_px": 15.0,
    "vertical_sustain_frames": 1,
    "fist_curl_threshold": 0.65,
    "fusion_agreement_window_s": 1.0,
    "cooldown_s": 2.0,
    "ha_event_name": "gesture_detected",
    "log_level": "info"
  },
  "schema": {
    "rtsp_url_a": "str",
    "rtsp_url_b": "str",
    "rtsp_transport": "list(tcp|udp)",
    "rtsp_reconnect_delay_s": "float",
    "frame_width": "int",
    "frame_height": "int",
    "hand_model_max_hands": "int",
    "hand_min_detection_confidence": "float",
    "hand_min_tracking_confidence": "float",
    "wave_velocity_threshold_px": "float",
    "wave_sustain_frames": "int",
    "vertical_velocity_threshold_px": "float",
    "vertical_sustain_frames": "int",
    "fist_curl_threshold": "float",
    "fusion_agreement_window_s": "float",
    "cooldown_s": "float",
    "ha_event_name": "str",
    "log_level": "list(debug|info|warning|error)"
  },
  "map": ["data"],
  "host_network": false,
  "homeassistant_api": true,
  "hassio_api": true,
  "auth_api": false,
  "ingress": false,
  "panel_icon": "mdi:hand-wave",
  "panel_title": "Gesture Cam"
}
