{
  "name": "Gesture Cam",
  "version": "1.0.2",
  "slug": "gesture_cam",
  "description": "Dual RTSP camera gesture detection — raises HA events on wave/palm/fist gestures.",
  "url": "https://github.com/your-repo/gesture-cam-addon",
  "init": true,
  "arch": ["aarch64", "amd64"],
  "startup": "application",
  "boot": "auto",
  "options": {
    "rtsp_url_a": "rtsp://user:pass@192.168.1.100:554/stream1",
    "rtsp_url_b": "rtsp://user:pass@192.168.1.101:554/stream1",
    "rtsp_transport": "tcp",
    "rtsp_reconnect_delay_s": 5.0,
    "frame_width": 640,
    "frame_height": 480,
    "pose_model_complexity": 0,
    "pose_min_detection_confidence": 0.6,
    "pose_min_tracking_confidence": 0.5,
    "arm_raised_wrist_above_shoulder_frac": 0.10,
    "wave_velocity_threshold_px": 18.0,
    "wave_sustain_frames": 3,
    "vertical_velocity_threshold_px": 15.0,
    "vertical_sustain_frames": 3,
    "fist_curl_threshold": 0.65,
    "fusion_agreement_window_s": 0.5,
    "cooldown_s": 1.2,
    "ha_event_name": "gesture_detected",
    "log_level": "info"
  },
  "schema": {
    "rtsp_url_a": "str",
    "rtsp_url_b": "str",
    "rtsp_transport": "list(tcp|udp)",
    "rtsp_reconnect_delay_s": "float",
    "frame_width": "int",
    "frame_height": "int",
    "pose_model_complexity": "list(0|1|2)",
    "pose_min_detection_confidence": "float",
    "pose_min_tracking_confidence": "float",
    "arm_raised_wrist_above_shoulder_frac": "float",
    "wave_velocity_threshold_px": "float",
    "wave_sustain_frames": "int",
    "vertical_velocity_threshold_px": "float",
    "vertical_sustain_frames": "int",
    "fist_curl_threshold": "float",
    "fusion_agreement_window_s": "float",
    "cooldown_s": "float",
    "ha_event_name": "str",
    "log_level": "list(debug|info|warning|error)"
  },
  "map": ["data"],
  "host_network": false,
  "homeassistant_api": true,
  "hassio_api": true,
  "auth_api": false,
  "ingress": false,
  "panel_icon": "mdi:hand-wave",
  "panel_title": "Gesture Cam"
}
