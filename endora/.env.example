# Copy this file to .env and fill in your values.
# .env is never committed to git.

# RTSP stream URLs for your two cameras
RTSP_URL_A=rtsp://admin:password@192.168.1.100:554/stream1
RTSP_URL_B=rtsp://admin:password@192.168.1.101:554/stream1

# Long-Lived Access Token from HA Profile page
HA_TOKEN=your_long_lived_token_here

# HA API URL — use localhost if endora runs on the same machine as HA
# Use the HA machine's IP if they're on different hosts
HA_URL=http://localhost:8123/api

# debug | info | warning | error
LOG_LEVEL=info
