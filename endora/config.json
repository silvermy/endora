{
  "name": "Endora",
  "version": "1.7.11",
  "slug": "endora",
  "description": "Gesture detection \u2014 arm above head + wrist flick/orientation/fist pump. Works from couch or standing.",
  "url": "https://github.com/silvermy/endora",
  "init": false,
  "arch": [
    "aarch64",
    "amd64"
  ],
  "startup": "application",
  "boot": "auto",
  "options": {
    "rtsp_url_a": "rtsp://user:pass@192.168.1.100:554/stream1",
    "rtsp_url_b": "rtsp://user:pass@192.168.1.101:554/stream1",
    "debug_port": 8765,
    "ha_event_name": "gesture_detected",
    "log_level": "info",

    "arm_above_head_tolerance": 0.05,
    "fist_curl_threshold": 0.75,
    "palm_twist_threshold": 0.40,
    "cooldown_s": 2.0,
    "pose_visibility_min": 0.35,
    "frame_crop_bottom": 0,

    "low_light_enhance": false,

    "dewarp_enable": false,
    "dewarp_fov": 180.0,
    "dewarp_tilt": 30.0,
    "dewarp_pan": 0.0,
    "dewarp_roll": 0.0,
    "dewarp_vfov": 75.0,
    "dewarp_out_width": 1280,
    "dewarp_out_height": 480
  },
  "schema": {
    "rtsp_url_a": "str",
    "rtsp_url_b": "str",
    "debug_port": "int",
    "ha_event_name": "str",
    "log_level": "list(debug|info|warning|error)",

    "arm_above_head_tolerance": "float",
    "fist_curl_threshold": "float",
    "palm_twist_threshold": "float",
    "mirror_camera": "bool",
    "cooldown_s": "float",
    "pose_visibility_min": "float",
    "frame_crop_bottom": "int",

    "low_light_enhance": "bool",

    "dewarp_enable": "bool",
    "dewarp_fov": "float",
    "dewarp_tilt": "float",
    "dewarp_pan": "float",
    "dewarp_roll": "float",
    "dewarp_vfov": "float",
    "dewarp_out_width": "int",
    "dewarp_out_height": "int"
  },
  "map": [
    "data"
  ],
  "host_network": false,
  "homeassistant_api": true,
  "hassio_api": true,
  "auth_api": false,
  "ingress": false,
  "panel_icon": "mdi:hand-wave",
  "panel_title": "Endora",
  "ports": {
    "8765/tcp": 8765
  }
}
