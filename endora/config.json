{
  "name": "Endora",
  "version": "1.9.68",
  "slug": "endora",
  "description": "Pose-based gesture detection — SNAP, HOLD, DOUBLE_SNAP, CROSS_ARMS, T_POSE, RAISE_BOTH.",
  "url": "https://github.com/silvermy/endora",
  "init": false,
  "arch": ["aarch64", "amd64"],
  "startup": "application",
  "boot": "auto",
  "options": {
    "rtsp_url_a": "rtsp://user:pass@192.168.1.100:554/stream1",
    "rtsp_url_b": "rtsp://user:pass@192.168.1.100:554/stream1",
    "debug_port": 8765,
    "ha_event_name": "gesture_detected",
    "log_level": "info",

    "yolo_conf": 0.30,
    "yolo_imgsz": 320,
    "motion_threshold": 0.015,
    "yolo_max_skip": 12,

    "arm_above_head_tolerance": 0.15,
    "body_upright_min": -0.50,
    "pose_visibility_min": 0.45,
    "snap_forearm_min": 0.10,
    "hold_duration_s": 1.5,
    "double_snap_window_s": 3.0,
    "sustain_s": 0.5,
    "state_confirm_s": 0.20,
    "state_release_s": 0.30,
    "cooldown_s": 2.0,
    "frame_crop_bottom": 0,
    "flip_image": false,
    "mirror_camera": false,
    "low_light_enhance": false,

    "chime_enable": false,
    "chime_entity_id": "",
    "chime_volume": 40,
    "chime_debounce_s": 4.0,

    "dewarp_enable": false,
    "dewarp_fov": 180.0,
    "dewarp_tilt": 30.0,
    "dewarp_pan": 0.0,
    "dewarp_roll": 0.0,
    "dewarp_vfov": 75.0,
    "dewarp_out_width": 1280,
    "dewarp_out_height": 480
  },
  "schema": {
    "rtsp_url_a": "str",
    "rtsp_url_b": "str",
    "debug_port": "int",
    "ha_event_name": "str",
    "log_level": "list(debug|info|warning|error)",

    "yolo_conf": "float",
    "yolo_imgsz": "int",
    "motion_threshold": "float",
    "yolo_max_skip": "int",

    "arm_above_head_tolerance": "float",
    "body_upright_min": "float",
    "pose_visibility_min": "float",
    "snap_forearm_min": "float",
    "hold_duration_s": "float",
    "double_snap_window_s": "float",
    "sustain_s": "float",
    "state_confirm_s": "float",
    "state_release_s": "float",
    "cooldown_s": "float",
    "frame_crop_bottom": "int",
    "flip_image": "bool",
    "mirror_camera": "bool",
    "low_light_enhance": "bool",

    "chime_enable": "bool",
    "chime_entity_id": "str",
    "chime_volume": "int",
    "chime_debounce_s": "float",

    "dewarp_enable": "bool",
    "dewarp_fov": "float",
    "dewarp_tilt": "float",
    "dewarp_pan": "float",
    "dewarp_roll": "float",
    "dewarp_vfov": "float",
    "dewarp_out_width": "int",
    "dewarp_out_height": "int"
  },
  "map": ["data", "media"],
  "host_network": false,
  "full_access": true,
  "homeassistant_api": true,
  "hassio_api": true,
  "auth_api": false,
  "ingress": true,
  "ingress_port": 8766,
  "panel_icon": "mdi:hand-wave",
  "panel_title": "Endora",
  "ports": {
    "8765/tcp": 8765,
    "8766/tcp": 8766
  }
}
