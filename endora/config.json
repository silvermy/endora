{
  "name": "Endora",
  "version": "1.7.39",
  "slug": "endora",
  "description": "Gesture detection — SNAP, HOLD, DOUBLE_SNAP, PEACE. Works from couch or standing.",
  "url": "https://github.com/silvermy/endora",
  "init": false,
  "arch": [
    "aarch64",
    "amd64"
  ],
  "startup": "application",
  "boot": "auto",
  "options": {
    "rtsp_url_a": "rtsp://user:pass@192.168.1.100:554/stream1",
    "rtsp_url_b": "rtsp://user:pass@192.168.1.101:554/stream1",
    "debug_port": 8765,
    "ha_event_name": "gesture_detected",
    "log_level": "info",

    "arm_above_head_tolerance": 0.15,
    "body_upright_min": -0.15,
    "leg_raise_margin": 0.20,
    "fist_curl_threshold": 0.75,
    "flip_image": false,
    "snap_forearm_min": 0.10,
    "hold_duration_s": 1.5,
    "double_snap_window_s": 3.0,
    "cooldown_s": 2.0,
    "pose_visibility_min": 0.45,
    "frame_crop_bottom": 0,
    "mirror_camera": false,

    "low_light_enhance": false,

    "dewarp_enable": false,
    "dewarp_fov": 180.0,
    "dewarp_tilt": 30.0,
    "dewarp_pan": 0.0,
    "dewarp_roll": 0.0,
    "dewarp_vfov": 75.0,
    "dewarp_out_width": 1280,
    "dewarp_out_height": 480
  },
  "schema": {
    "rtsp_url_a": "str",
    "rtsp_url_b": "str",
    "debug_port": "int",
    "ha_event_name": "str",
    "log_level": "list(debug|info|warning|error)",

    "arm_above_head_tolerance": "float",
    "body_upright_min": "float",
    "leg_raise_margin": "float",
    "fist_curl_threshold": "float",
    "flip_image": "bool",
    "snap_forearm_min": "float",
    "hold_duration_s": "float",
    "double_snap_window_s": "float",
    "cooldown_s": "float",
    "pose_visibility_min": "float",
    "frame_crop_bottom": "int",
    "mirror_camera": "bool",

    "low_light_enhance": "bool",

    "dewarp_enable": "bool",
    "dewarp_fov": "float",
    "dewarp_tilt": "float",
    "dewarp_pan": "float",
    "dewarp_roll": "float",
    "dewarp_vfov": "float",
    "dewarp_out_width": "int",
    "dewarp_out_height": "int"
  },
  "map": [
    "data"
  ],
  "host_network": false,
  "homeassistant_api": true,
  "hassio_api": true,
  "auth_api": false,
  "ingress": true,
  "ingress_port": 8766,
  "panel_icon": "mdi:hand-wave",
  "panel_title": "Endora",
  "ports": {
    "8765/tcp": 8765,
    "8766/tcp": 8766
  }
}
